import F1Square.Square.AtlasModular

namespace UOR.Bridge.F1Square.Square

-- ===========================================================================
-- The exceptional series and the rank¬∑(h+1) dimension law.
-- ===========================================================================

/-- **The uniform dimension law `dim ùî§ = rank ¬∑ (h + 1)`** (rank √ó (Coxeter number + 1)) across the
    exceptional series: `G‚ÇÇ(2,6)=14`, `F‚ÇÑ(4,12)=52`, `E‚ÇÜ(6,12)=78`, `E‚Çá(7,18)=133`, `E‚Çà(8,30)=248`. -/
theorem exceptional_dims :
    2 * (6 + 1) = 14 ‚àß 4 * (12 + 1) = 52 ‚àß 6 * (12 + 1) = 78
    ‚àß 7 * (18 + 1) = 133 ‚àß 8 * (30 + 1) = 248 := by decide

/-- **The magic-square octonion row**, generated by `R, C, H, O`: the first algebra (dim `2^j`,
    the tower level) selects the exceptional algebra of the octonion row, `R‚Ü¶F‚ÇÑ, C‚Ü¶E‚ÇÜ, H‚Ü¶E‚Çá, O‚Ü¶E‚Çà`
    ‚Äî each paired `(tower-level dim, exceptional dim)`. The `(O,O)` corner `(8, 248)` is `E‚Çà`, the
    tower's top. -/
theorem magic_square_octonion_row :
    ((2 ^ 0, 52) = (1, 52)) ‚àß ((2 ^ 1, 78) = (2, 78))
    ‚àß ((2 ^ 2, 133) = (4, 133)) ‚àß ((2 ^ 3, 248) = (8, 248)) := by decide

-- ===========================================================================
-- The connections back to {T, O}.
-- ===========================================================================

/-- **`dim G‚ÇÇ` is over-determined**: `rank¬∑(h+1) = 2¬∑7 = (T‚àí1)(O‚àí1) = 14` ‚Äî the Coxeter law and the
    Atlas reflection multiplicity agree. `G‚ÇÇ = Aut(O)`, rank `T‚àí1 = 2`, `h+1 = O‚àí1 = 7`. -/
theorem g2_coxeter_atlas : 2 * (6 + 1) = 14 ‚àß (3 - 1) * (8 - 1) = 14 := by decide

/-- **`E‚Çà` is the tower's top ‚Äî the `(O,O)` corner**: rank `= O = 8`, dimension `8¬∑(30+1) = 248`. -/
theorem e8_top : (8 : Nat) = 8 ‚àß 8 * (30 + 1) = 248 := by decide

/-- **`240` is over-determined as the E‚Çà root count**: `dim E‚Çà ‚àí rank E‚Çà = 248 ‚àí 8 = 240` ‚Äî the
    kissing number / number of roots ‚Äî the SAME `240` as the Eisenstein coefficient `Œ∏_{E‚Çà} = E‚ÇÑ`
    (`e8_theta_E4`, `AtlasCharacteristics`). -/
theorem twoForty_roots : 248 - 8 = 240 ‚àß 240 * sig3 1 = 240 := by decide

end UOR.Bridge.F1Square.Square
